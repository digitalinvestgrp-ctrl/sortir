# Trouvetateam — .env example
# NEVER commit .env (real) in Git. Cree .env.local en local et .env directement sur le FTP en prod.

APP_NAME=trouvetateam
APP_ENV=production
APP_URL=https://www.trouvetateam.fr
APP_DEBUG=false
APP_KEY=

# OVH CloudDB cluster -002, base trouvetateam, user safeprotek (re-utilise creds Safeprotek)
DB_HOST=cs1023012-002.eu.clouddb.ovh.net
DB_PORT=35114
DB_USER=safeprotek
DB_PASS=
DB_NAME=trouvetateam

# Gate 18+ (veto Tomas)
MIN_AGE=18

# Discovery defaults
DEFAULT_RADIUS_M=3000
MAX_RADIUS_M=10000

# SMS : par defaut MOCK (gratuit, regle DIG : pas de service payant sans GO Stephane)
SMS_DRIVER=log
SMS_EXPOSE_CODE=true

# Token de garde pour migrations/seed (one-shot)
MIGRATIONS_TOKEN=
